3. XSS : Cross-Site Scripting
suricataalert http any any -> any any (
  msg:"XSS - Script Tag Detected";
  flow:established,to_server;
  content:"<script>"; nocase; http_uri;
  classtype:web-application-attack;
  sid:100010; rev:1;
)

alert http any any -> any any (
  msg:"XSS , JavaScript Event Handler";
  flow:established,to_server;
  pcre:"/on(load|click|mouseover|error|focus)\s*=/i";
  http_uri;
  classtype:web-application-attack;
  sid:100011; rev:1;
)

alert http any any -> any any (
  msg:"XSS - Encoded Bypass Attempt";
  flow:established,to_server;
  content:"%3Cscript%3E"; nocase; http_uri;
  classtype:web-application-attack;
  sid:100012; rev:1;
)

