1. Brute Force
suricataalert http any any -> any any (
  msg:"Brute Force , HTTP Login Attempt";
  flow:established,to_server;
  content:"POST"; http_method;
  content:"password="; http_client_body; nocase;
  threshold:type threshold, track by_src, count 10, seconds 5;
  classtype:attempted-recon;
  sid:100030; rev:1;
)

alert tcp any any -> $HOME_NET 22 (
  msg:"Brute Force , SSH Multiple Attempts";
  flags:S;
  threshold:type threshold, track by_src, count 5, seconds 10;
  classtype:attempted-recon;
  sid:100031; rev:1;
)
